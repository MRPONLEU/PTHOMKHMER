rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Default-Deny Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Security Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getEmail() {
      return request.auth != null ? request.auth.token.email.lower() : "";
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        getEmail() == "broponleu998@gmail.com" ||
        getEmail() == "mrponleu20000@gmail.com"
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() &&
        (
          (exists(/databases/$(database)/documents/admins/$(getEmail())) && get(/databases/$(database)/documents/admins/$(getEmail())).data.role in ['admin', 'master', 'editor']) ||
          (exists(/databases/$(database)/documents/users/$(getEmail())) && get(/databases/$(database)/documents/users/$(getEmail())).data.role in ['admin', 'master', 'editor'])
        )
      );
    }
    
    function isUserPro() {
      return isSuperAdmin() || isAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(getEmail())) &&
        get(/databases/$(database)/documents/users/$(getEmail())).data.role == 'user pro'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. Collection Rules

    // --- Admins Collection (Legacy, keep for backwards compat) ---
    match /admins/{adminEmail} {
      // Admins are identified by their lowercase email as the document ID
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    // --- Users Collection ---
    match /users/{userEmail} {
      allow read: if true;
      // Allow creation of user records by anyone (to support registration / simulated fallback)
      allow create: if 
        (resource == null && (!("role" in request.resource.data) || request.resource.data.role == 'user'))
        || isAdmin();
      // Allow updates to own record by signed in user, but prevent role elevation
      allow update: if 
        (isSignedIn() && getEmail() == userEmail && (
          (!("role" in request.resource.data) || request.resource.data.role == 'user') ||
          (resource != null && "role" in resource.data && request.resource.data.role == resource.data.role)
        )) 
        || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Categories Collection ---
    match /categories/{categoryId} {
      allow read: if true; // Public catalogs are publicly readable
      allow create, update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();

      function isValidCategory(data) {
        return data.keys().hasAll(['id', 'name', 'subTypes'])
          && data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.subTypes is list && data.subTypes.size() <= 50;
      }
    }

    // --- Video Categories Collection ---
    match /video_categories/{videoCategoryId} {
      allow read: if true; // Public catalogs are publicly readable
      allow create, update: if isAdmin() && isValidVideoCategory(request.resource.data);
      allow delete: if isAdmin();

      function isValidVideoCategory(data) {
        return data.keys().hasAll(['id', 'name', 'subTypes'])
          && data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.subTypes is list && data.subTypes.size() <= 50;
      }
    }

    // --- Documents Collection ---
    match /docs/{docId} {
      allow read: if true;

      allow create: if isAdmin() && isValidDoc(request.resource.data);
      allow delete: if isAdmin();

      allow update: if (
        // Admin full update authorization
        (isAdmin() && isValidDoc(request.resource.data)) ||
        // Visitor/regular user update authorization (ONLY allowed to increment download count by exactly 1)
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloads']) &&
          request.resource.data.downloads == resource.data.downloads + 1 
        )
      );

      function isValidDoc(data) {
        return data.keys().hasAll(['id', 'title', 'downloadUrl', 'uploadDate', 'downloads'])
          && data.id is string
          && data.title is string
          && (!("description" in data) || data.description == null || data.description is string)
          && (!("coverUrl" in data) || data.coverUrl == null || data.coverUrl is string)
          && data.downloadUrl is string
          && data.uploadDate is string
          && (data.downloads is int || data.downloads is float)
          && (!("type" in data) || data.type == null || data.type is string)
          && (!("subType" in data) || data.subType == null || data.subType is string)
          && (!("isHidden" in data) || data.isHidden == null || data.isHidden is bool)
          && (!("isFree" in data) || data.isFree == null || data.isFree is bool)
          && (!("tags" in data) || data.tags == null || data.tags is list)
          && (!("youtubeUrl" in data) || data.youtubeUrl == null || data.youtubeUrl is string)
          && (!("duration" in data) || data.duration == null || data.duration is string)
          && (!("instructor" in data) || data.instructor == null || data.instructor is string)
          && (!("lessonOrder" in data) || data.lessonOrder == null || data.lessonOrder is int || data.lessonOrder is float)
          && (!("fileSize" in data) || data.fileSize == null || data.fileSize is string)
          && (!("fileType" in data) || data.fileType == null || data.fileType is string);
      }
    }
  }
}
